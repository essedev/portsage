{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grimport",
  "version": "0.2.0",
  "identifier": "com.doppia.grimport",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Grimport",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 400,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "popover",
        "title": "Grimport",
        "width": 350,
        "height": 480,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
