{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Portsage",
  "version": "0.6.1",
  "identifier": "com.doppia.portsage",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Portsage",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 400,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "transparent": true,
        "backgroundColor": "#222228"
      },
      {
        "label": "popover",
        "title": "Portsage",
        "width": 350,
        "height": 480,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../mcp/server.py": "mcp/server.py",
      "../mcp/pyproject.toml": "mcp/pyproject.toml",
      "../mcp/SKILL.md": "mcp/SKILL.md"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
